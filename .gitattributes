# Enforce LF line endings on all text files regardless of the OS / core.autocrlf,
# so the packaged module always satisfies the PrestaShop validator's `line_ending` rule.
* text=auto eol=lf

# Binary assets must never be line-ending normalised.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary

# Dev-only files — excluded from `git archive` (the distributed module zip) so the
# validator never sees them (e.g. the php-cs-fixer config has no _PS_VERSION_ guard
# by design — it is a standalone tooling file, not module runtime code).
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
.php-cs-fixer.dist.php export-ignore
.php-cs-fixer.cache export-ignore
views/.vite/ export-ignore
